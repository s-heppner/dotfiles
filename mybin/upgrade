#!/usr/bin/env bash
#
# Upgrade system packages: apt/dnf, snap, flatpak.
#
# Usage:
#
#   upgrade

set -euo pipefail

if command -v apt &>/dev/null; then
    echo "==> apt"
    sudo apt update && apt list --upgradable
    sudo apt upgrade
elif command -v dnf &>/dev/null; then
    echo "==> dnf"
    sudo dnf upgrade
else
    echo "Error: no supported package manager found (apt, dnf)." >&2
    exit 1
fi

if command -v snap &>/dev/null; then
    echo "==> snap"
    sudo snap refresh
fi

if command -v flatpak &>/dev/null; then
    echo "==> flatpak"
    sudo flatpak update -y
fi
