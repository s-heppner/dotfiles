#!/usr/bin/env bash
#
# Split files in a directory into numbered chunk subdirectories.
#
# Usage:
#
#   chunk-move <directory> <chunk-size>

set -euo pipefail

usage() {
    echo "Usage: chunk-move <directory> <chunk-size>"
}

if [[ "$#" -ne 2 ]]; then
    usage >&2
    exit 2
fi

dir="$1"
chunk_size="$2"

if [[ ! -d "$dir" ]]; then
    echo "Error: '$dir' is not a directory." >&2
    exit 2
fi
if ! [[ "$chunk_size" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: chunk-size must be a positive integer." >&2
    exit 2
fi

file_count=$(find "$dir" -mindepth 1 -maxdepth 1 -type f -print0 | tr -cd '\0' | wc -c)
if (( file_count == 0 )); then
    echo "No files to move in '$dir'."
    exit 0
fi

chunks=$(( (file_count + chunk_size - 1) / chunk_size ))
pad=${#chunks}
(( pad < 2 )) && pad=2

i=0
current_chunk=0
pushd "$dir" >/dev/null

find . -maxdepth 1 -type f -print0 |
while IFS= read -r -d '' f; do
    this_chunk=$(( i / chunk_size + 1 ))
    if (( this_chunk != current_chunk )); then
        current_chunk=$this_chunk
        printf "→ Moving files into chunk-%0*d\n" "$pad" "$current_chunk"
    fi

    local_subdir=$(printf "chunk-%0*d" "$pad" "$current_chunk")
    mkdir -p "$local_subdir"
    mv -n -- "$f" "$local_subdir"/

    ((i++))
done

popd >/dev/null
echo "Done. Moved $file_count files into $chunks chunk directories."
