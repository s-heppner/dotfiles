#!/usr/bin/env bash
#
# Manage named SSH tunnels.
#
# Config file: ~/.tunnel.conf
#
# Example:
#
#   [home-assistant]
#   LOCAL_HOST=127.0.0.1
#   LOCAL_PORT=8123
#   REMOTE_HOST=192.168.1.2
#   REMOTE_PORT=8123
#   SSH_HOST=home
#
#   [lm-studio]
#   LOCAL_HOST=127.0.0.1
#   LOCAL_PORT=1234
#   REMOTE_HOST=192.168.1.2
#   REMOTE_PORT=1234
#   SSH_HOST=home
#
# Usage:
#
#   tunnel <name> [up|down|toggle|status]
#   tunnel list
#
# PID files are stored as ~/.tunnel-<name>.pid

set -euo pipefail

CONF_FILE="${HOME}/.tunnel.conf"

die() {
    echo "Error: $*" >&2
    exit 1
}

check_conf_file() {
    if [[ ! -f "$CONF_FILE" ]]; then
        cat >&2 <<EOF
Error: missing config file: $CONF_FILE

Create it with one or more tunnel sections, e.g.:

  [home-assistant]
  LOCAL_HOST=127.0.0.1
  LOCAL_PORT=8123
  REMOTE_HOST=192.168.1.2
  REMOTE_PORT=8123
  SSH_HOST=home

Then rerun this script.
EOF
        exit 1
    fi
}

load_tunnel() {
    local name="$1"
    local in_section=0

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# || -z "${line// }" ]] && continue

        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            [[ $in_section -eq 1 ]] && break
            [[ "${BASH_REMATCH[1]}" == "$name" ]] && in_section=1
            continue
        fi

        if [[ $in_section -eq 1 && "$line" =~ ^([A-Z_]+)=(.*)$ ]]; then
            eval "${BASH_REMATCH[1]}=${BASH_REMATCH[2]}"
        fi
    done < "$CONF_FILE"

    [[ $in_section -eq 0 ]] && die "no tunnel named '$name' in $CONF_FILE"

    PID_FILE="${HOME}/.tunnel-${name}.pid"

    : "${LOCAL_HOST:?missing LOCAL_HOST for [$name] in $CONF_FILE}"
    : "${LOCAL_PORT:?missing LOCAL_PORT for [$name] in $CONF_FILE}"
    : "${REMOTE_HOST:?missing REMOTE_HOST for [$name] in $CONF_FILE}"
    : "${REMOTE_PORT:?missing REMOTE_PORT for [$name] in $CONF_FILE}"
    : "${SSH_HOST:?missing SSH_HOST for [$name] in $CONF_FILE}"
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

is_running() {
    [[ -f "$PID_FILE" ]] || return 1
    local pid
    pid="$(cat "$PID_FILE")"
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" >/dev/null 2>&1
}

tunnel_up() {
    need_cmd ssh

    if is_running; then
        echo "Tunnel already running."
        echo "PID: $(cat "$PID_FILE")"
        echo "URL: http://${LOCAL_HOST}:${LOCAL_PORT}"
        exit 0
    fi

    rm -f "$PID_FILE"

    echo "Starting tunnel:"
    echo "  local:  ${LOCAL_HOST}:${LOCAL_PORT}"
    echo "  remote: ${REMOTE_HOST}:${REMOTE_PORT}"
    echo "  ssh:    ${SSH_HOST}"

    ssh -fN \
        -L "${LOCAL_HOST}:${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" \
        -o ExitOnForwardFailure=yes \
        -o ServerAliveInterval=15 \
        -o ServerAliveCountMax=3 \
        "$SSH_HOST"

    # Find the tunnel process. Yes, this is ugly. So is process management in shell.
    local pid
    pid="$(pgrep -f "ssh .*${LOCAL_HOST}:${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}.*${SSH_HOST}" | head -n 1 || true)"

    if [[ -z "$pid" ]]; then
        die "tunnel seems to have started, but could not find SSH process"
    fi

    echo "$pid" > "$PID_FILE"

    echo "Tunnel started."
    echo "PID: $pid"
    echo "URL: http://${LOCAL_HOST}:${LOCAL_PORT}"
}

tunnel_down() {
    if ! is_running; then
        echo "Tunnel not running."
        rm -f "$PID_FILE"
        exit 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    echo "Stopping tunnel PID $pid"
    kill "$pid"
    rm -f "$PID_FILE"
    echo "Tunnel stopped."
}

tunnel_status() {
    if is_running; then
        echo "Tunnel running."
        echo "PID: $(cat "$PID_FILE")"
        echo "URL: http://${LOCAL_HOST}:${LOCAL_PORT}"
    else
        echo "Tunnel not running."
        rm -f "$PID_FILE"
    fi
}

tunnel_list() {
    local name
    while IFS= read -r name; do
        PID_FILE="${HOME}/.tunnel-${name}.pid"
        if is_running; then
            echo "  ${name}  [running, PID $(cat "$PID_FILE")]"
        else
            echo "  ${name}  [stopped]"
        fi
    done < <(grep -E '^\[.+\]$' "$CONF_FILE" | sed 's/^\[//;s/\]$//' || true)
}

check_conf_file

TUNNEL_NAME="${1:-}"
SUBCOMMAND="${2:-toggle}"

case "$TUNNEL_NAME" in
    ""|list)
        tunnel_list
        exit 0
        ;;
esac

load_tunnel "$TUNNEL_NAME"

case "$SUBCOMMAND" in
    up|start)
        tunnel_up
        ;;
    down|stop)
        tunnel_down
        ;;
    toggle)
        if is_running; then
            tunnel_down
        else
            tunnel_up
        fi
        ;;
    status)
        tunnel_status
        ;;
    *)
        echo "Usage: $(basename "$0") <name> [up|down|toggle|status]" >&2
        echo "       $(basename "$0") list" >&2
        exit 2
        ;;
esac
